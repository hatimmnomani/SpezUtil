{
  "name": "@spezutil/hijri-calendar",
  "version": "0.1.3",
  "description": "Hijri-first interactive calendar view Web Component (month, week, day, agenda) with event support.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hatimmnomani/SpezUtil.git",
    "directory": "packages/hijri-calendar"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@spezutil/hijri-core": "workspace:^",
    "@spezutil/hijri-view-core": "workspace:^"
  },
  "devDependencies": {
    "jsdom": "^25.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
